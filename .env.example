# PlanKP Backend - Konfigurasi Environment

# Port server Express berjalan
PORT=3000

# Lingkungan aplikasi: development / production / test
NODE_ENV=development

# --- Konfigurasi Database Utama (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=plan_kp_database
DB_USER=root
DB_PASSWORD=your_db_password

# Schema database pendukung/pabrik (Helper database, e.g. 'kencanaprint')
DB_HELPER=kencanaprint

# Schema database HRD untuk sinkronisasi data hari libur nasional (e.g. 'db_hrd')
DB_HRD=db_hrd

# --- Autentikasi JWT (JSON Web Token) ---
# Gunakan string acak yang panjang dan aman di produksi
JWT_SECRET=your_super_secret_key_min_32_chars
JWT_EXPIRES_IN=8h